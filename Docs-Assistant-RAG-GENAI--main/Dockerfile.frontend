# Frontend Dockerfile
FROM node:18-slim AS builder

WORKDIR /app

# Copy package files and install
COPY frontend-react/package*.json ./
RUN npm install

# Copy source and build
COPY frontend-react/ .
RUN npm run build

# Use Nginx to serve
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
